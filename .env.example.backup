# Base de datos para docker-compose
POSTGRES_DB=dbejemplo
POSTGRES_USER=userejemplo
POSTGRES_PASSWORD=passwordejemplo

# JWT
APP_SECURITY_JWT_SECRET=una-clave-larga-de-al-menos-32-bytes-para-hs256
APP_SECURITY_JWT_EXPIRATION_MS=3600000

# Config opcional
APP_SQL_SHOW=true

# Para correr backend local sin docker (opcional)
SPRING_DATASOURCE_URL=jdbcejemplo
SPRING_DATASOURCE_USERNAME=userejemplo
SPRING_DATASOURCE_PASSWORD=passwordejemplo
